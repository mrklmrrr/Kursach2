# Порт сервера
PORT=5001

# Секретный ключ JWT (обязательно)
JWT_SECRET=change_me_very_long_random_secret

# Срок действия JWT токена
JWT_EXPIRES_IN=15m
JWT_ISSUER=kursach-backend
JWT_AUDIENCE=kursach-frontend

# MongoDB URI (обязательно)
# Локальная: mongodb://localhost:27017/kursach
# MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/kursach
MONGO_URI=mongodb://localhost:27017/kursach

# URL фронтенда (для CORS)
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173

# Публичный URL API (для ссылок на загруженные аватары). В проде: https://api.yourdomain.com
# PUBLIC_API_BASE=http://localhost:5001

# Окружение (development | production)
NODE_ENV=development

# --- Пояснения к лабораторным результатам для пациента (ИИ, опционально) ---
# Нужен Node 18+ (встроенный fetch). Задайте ключ в backend/.env и перезапустите сервер.
# Без OPENAI_API_KEY пациент получит краткую статическую справку; с ключом — текст от модели (Chat Completions).
# OPENAI_API_KEY=sk-...
# OpenRouter: нужен положительный баланс (пополнение в настройках аккаунта), иначе 402 Insufficient credits.
# Если видите 403 unsupported_country — запросы шли на api.openai.com из региона без доступа к OpenAI.
# Решение: OpenRouter (ключ и база с openrouter.ai), не смешивайте ключ OpenRouter с базой OpenAI.
# OPENAI_API_BASE=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o-mini
# Опционально для OpenRouter (ранжирование в каталоге):
# OPENROUTER_HTTP_REFERER=http://localhost:5173
# OPENROUTER_APP_TITLE=Мой медпроект
# Прямой OpenAI (только из поддерживаемых регионов):
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# Таймаут запроса к ИИ (мс), по умолчанию 55000:
# OPENAI_TIMEOUT_MS=55000

# --- Настройки администратора (создаётся при первом запуске) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin_password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_PHONE=+70000000000

# --- Демо и продажи ---
# Для сценария из DEMO.md используйте ADMIN_EMAIL / ADMIN_PASSWORD.

# --- Напоминания о приёме (воркер cron каждые 10 мин) ---
# REMINDERS_ENABLED=false  — полностью выключить
# TZ=Europe/Minsk          — таймзона для cron (опционально)
#
# Почта (nodemailer):
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="Мед24 <noreply@example.com>"
#
# Telegram: создайте бота у @BotFather, укажите токен; пациент сохраняет telegramChatId в профиле.
# TELEGRAM_BOT_TOKEN=123456:ABC...
