# Порт сервера
PORT=5001

# Секретный ключ JWT (обязательно)
JWT_SECRET=change_me_very_long_random_secret

# Срок действия JWT токена
JWT_EXPIRES_IN=15m
JWT_ISSUER=kursach-backend
JWT_AUDIENCE=kursach-frontend

# MongoDB URI (обязательно)
# Локальная: mongodb://localhost:27017/kursach
# MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/kursach
MONGO_URI=mongodb://localhost:27017/kursach

# URL фронтенда (для CORS)
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173

# Окружение (development | production)
NODE_ENV=development

# --- Настройки администратора (создаётся при первом запуске) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin_password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_PHONE=+70000000000
